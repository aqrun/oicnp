{
  "cSpell.words": [
      "oicnp", "dotenv", "graphiql", "chrono", "consts", "aqrun",
  ],
  "eslint.workingDirectories": [
    {
      "pattern": "apps/web",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "pattern": "apps/backend",
      "cwd": "${workspaceFolder}/apps/backend"
    }
  ],
  "eslint.experimental.useFlatConfig": true,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.nodePath": "",
  "eslint.packageManager": "pnpm",
  "eslint.run": "onType",
  "eslint.enable": true
}
