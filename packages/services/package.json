{
  "name": "@repo/services",
  "type": "module",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc"
  },
  "exports": {
    "./consts": {
      "types": "./src/consts.ts",
      "default": "./dist/consts.js"
    },
    "./request": {
      "types": "./src/request.ts",
      "default": "./dist/request.js"
    },
    "./action_request": {
      "types": "./src/action_request.ts",
      "default": "./dist/action_request.js"
    },
    "./types": {
