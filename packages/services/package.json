      "default": "./dist/useFetchStore.js"
    }
  },
  "devDependencies": {
    "zustand": "^5.0.2",
    "@repo/config-typescript": "workspace:*",
    "axios": "^1.7.7",
    "js-cookie": "^3.0.5",
    "@types/js-cookie": "^3.0.6",
